# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos ─────────────────────────────────────────────
# postgresql://USUARIO:PASSWORD@HOST:5432/NOMBRE_BD
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/avisos_isc
DB_SSL=false   # true en Oracle Cloud producción

# ── JWT ───────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_muy_largo_y_random
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=*   # En producción pon el dominio exacto

# ── Firebase Cloud Messaging ──────────────────────────────────
# Recomendado en VM: apunta al JSON del service account.
FIREBASE_SERVICE_ACCOUNT_PATH=/home/ubuntu/avisos_isc/keys/firebase-admin.json

# Alternativa local sin archivo JSON:
# FIREBASE_PROJECT_ID=tu_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu_project_id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
